{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf .*)",
      "PowerShell(Remove-Item -Recurse -Force C:\\*)"
    ],
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(find*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(touch*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git tag*)",
      "Bash(git stash*)",
      "Bash(git restore*)",
      "Bash(git switch*)",
      "Bash(git push*)",
      "Bash(gh release*)",
      "Bash(gh run*)",
      "Bash(jezpress*)",
      "Bash(robocopy*)",
      "Bash(php*)",
      "Bash(phpcs*)",
      "Bash(php-cs-fixer*)",
      "Bash(phpunit*)",
      "Bash(./vendor/bin/*)",
      "Bash(composer*)",
      "Bash(npm*)",
      "Bash(npx*)",
      "Bash(node*)",
      "Bash(yarn*)",
      "Bash(pnpm*)",
      "Bash(wp *)",
      "Bash(eslint*)",
      "Bash(prettier*)",
      "Bash(tsc*)",
      "Bash(vite*)",
      "Bash(zip*)",
      "PowerShell(Get-ChildItem*)",
      "PowerShell(Get-Content*)",
      "PowerShell(Select-String*)",
      "PowerShell(Test-Path*)",
      "PowerShell(New-Item*)",
      "PowerShell(robocopy*)",
      "PowerShell(php*)",
      "PowerShell(composer*)",
      "PowerShell(npm*)",
      "PowerShell(npx*)",
      "PowerShell(node*)",
      "PowerShell(git add*)",
      "PowerShell(git commit*)",
      "PowerShell(git tag*)",
      "PowerShell(git push*)"
    ],
    "ask": [
      "Bash(git reset --hard*)",
      "Bash(git checkout*)",
      "Bash(mv*)",
      "Bash(rm *)",
      "Bash(gh repo*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "PowerShell(Remove-Item*)",
      "PowerShell(Invoke-RestMethod*)",
      "PowerShell(Invoke-WebRequest*)",
      "Read(**/.jezpress-token)",
      "Read(**/.claude/memory/**)"
    ]
  }
}
